<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WhisperKeyboard.MainWindow"
        Title="Whisper Keyboard"
        Width="400"
        Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Status Section -->
        <Border Grid.Row="0" Background="#2d2d2d" Padding="15" CornerRadius="8" Margin="10,10,10,5">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusDetail"
                           Text="Click Start to begin listening"
                           FontSize="12"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Volume Meter -->
        <Border Grid.Row="1" Background="#2d2d2d" Padding="15" CornerRadius="8" Margin="10,5">
            <StackPanel>
                <TextBlock Text="Volume Level" FontSize="12" Foreground="#888888" Margin="0,0,0,5"/>
                <ProgressBar x:Name="VolumeBar"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Height="20"
                             CornerRadius="4"/>
                <TextBlock x:Name="VolumeText"
                           Text="0"
                           FontSize="10"
                           Foreground="#666666"
                           HorizontalAlignment="Right"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Transcription History -->
        <Border Grid.Row="2" Background="#2d2d2d" Padding="15" CornerRadius="8" Margin="10,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Recent Transcriptions" FontSize="12" Foreground="#888888" Margin="0,0,0,10"/>
                <ListBox x:Name="HistoryList"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3d3d3d" Padding="10" CornerRadius="4" Margin="0,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding PreviewText}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FormattedTime}" FontSize="10" Foreground="#666666" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="StartButton"
                    Content="Start Listening"
                    Click="OnStartClick"
                    Width="120"
                    Height="40"
                    Margin="5"/>
            <Button x:Name="StopButton"
                    Content="Stop"
                    Click="OnStopClick"
                    Width="80"
                    Height="40"
                    Margin="5"
                    IsEnabled="False"/>
            <Button x:Name="TranscribeFileButton"
                    Content="Transcribe File"
                    Click="OnTranscribeFileClick"
                    Width="120"
                    Height="40"
                    Margin="5"/>
            <Button x:Name="SettingsButton"
                    Content="Settings"
                    Click="OnSettingsClick"
                    Width="80"
                    Height="40"
                    Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
