<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WhisperKeyboard.FileTranscriptionWindow"
        Title="Transcribe File"
        Width="550"
        Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto" Margin="15">

        <!-- Drop Zone -->
        <Border x:Name="DropZone"
                Grid.Row="0"
                Background="#2d2d2d"
                BorderBrush="#555555"
                BorderThickness="2"
                CornerRadius="8"
                Padding="30"
                Margin="0,0,0,10"
                DragDrop.AllowDrop="True"
                PointerPressed="OnDropZoneClicked">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="DropZoneIcon"
                           Text="📁"
                           FontSize="40"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="DropZoneText"
                           Text="Drag &amp; drop an audio/video file here, or click to browse"
                           FontSize="14"
                           Foreground="#aaaaaa"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock x:Name="FileNameText"
                           Text=""
                           FontSize="12"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
                <TextBlock Text="MP3, WAV, OGG, M4A, FLAC, WEBM, MP4, MOV, MKV"
                           FontSize="10"
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Progress + Result -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <!-- Status -->
            <StackPanel Grid.Row="0" Margin="0,0,0,5">
                <TextBlock x:Name="StatusText"
                           Text=""
                           FontSize="12"
                           Foreground="#888888"/>
                <ProgressBar x:Name="ProgressBar"
                             IsIndeterminate="True"
                             Height="4"
                             Margin="0,5,0,0"
                             IsVisible="False"/>
            </StackPanel>

            <!-- Transcription Result -->
            <TextBox x:Name="ResultTextBox"
                     Grid.Row="1"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Watermark="Transcription will appear here..."
                     Background="#1e1e1e"
                     CornerRadius="4"/>
        </Grid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="8">
            <Button x:Name="CopyButton"
                    Content="Copy"
                    Click="OnCopyClick"
                    Width="80"
                    Height="35"
                    IsEnabled="False"/>
            <Button Content="Close"
                    Click="OnCloseClick"
                    Width="80"
                    Height="35"/>
        </StackPanel>

    </Grid>
</Window>
